<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Youtube Backend</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="w-full min-h-screen p-10 bg-zinc-900 text-white" >
        <h3 class="text-3xl mb-5" >Login your Account</h3>
        <form action="/login" method="post">
            <input class="px-3 py-2 outline-none border-2 border-zinc-700 rounded-lg" type="email" placeholder="email" name="email" >
            <input class="px-3 py-2 outline-none border-2 border-zinc-700 rounded-lg" type="password" placeholder="password" name="password" >
            <input class="px-5 py-2 bg-blue-500 rounded-lg" type="submit" value="Login" >       
        </form>
    </div>
    
</body>
</html>