<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Youtube Backend</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="w-full min-h-screen p-10 bg-zinc-900 text-white" >
        <div class="w-full flex justify-end" >
             <a class="bg-red-600 px-9 py-2 inline-block mb-5 border-none rounded-lg text-sm" href="/logout">Logout</a>
        </div>
        <div class="flex items-start gap-3">
            <div class="w-10 h-10 bg-zinc-700 rounded-xl overflow-hidden" >
                <img 
                    class="w-full h-full object-cover"
                    src="/images/uploads/<%= user.profilepic %>" 
                    alt="profile pic"
                >
            </div>
            <h3 class="text-3xl mb-5" >Hello , <%= user.name %> 👋🏻</h3>
            
        </div>
        <h4 class="mb-5 mt-3" >You can create a new post</h4>
        <!-- Form for creating a post -->
        <form action="/post" method="post">
            <textarea  
                placeholder="What's on your mind..."
                class="w-1/3 p-3 bg-transparent resize-none border-2 border-zinc-700 rounded-lg" 
                name="content" 
                id="" 
            ></textarea>
            <input class=" px-9 py-2 rounded-lg cursor-pointer block mt-2 bg-blue-500 text-sm   " type="submit" value="Create new Post" >
        </form>

        <!-- All the Posts are here -->
        <div class="posts mt-20">
            <h3 class="text-2xl text-zinc-400 mb-1" >Your Posts</h3>
            <hr class="border-t border-zinc-700 mb-4" />
            <div class="postcontainer flex gap-5" >
                <% user.posts.reverse().forEach( post  => { %>
                    <div class="post w-1/3 p-5 rounded-md border-[1px] border-zinc-700 bg-zinc-800 transition-transform duration-500 hover:scale-105 ">
                        <div class="flex gap-1">
                            <div class="w-6 h-6 bg-zinc-700 rounded-full overflow-hidden" >
                                <img 
                                    class="w-full h-full object-cover"
                                    src="/images/uploads/<%= user.profilepic %>" 
                                    alt="profile pic"
                                >
                            </div>
                            <h3 class="bg-yellow-600 inline-block rounded-md px-2 mb-2" >@<%= user.username %></h3>
                        </div>
                        
                        <p class="text-sm tracking-tight" ><%= post.content %></p>
                        
                        <small class="inline-block mt-4" >
                            <%= post.likes.length %> likes
                        </small>
                        
                        <div class="btns flex gap-10 mt-2">
                            <a class="text-blue-500" href="/like/<%= post._id %>">
                                <%= post.likes.indexOf(user._id) === -1 ? "Like" : "Unlike" %>
                            </a>
                            <a class="text-zinc-500" href="/edit/<%= post._id %>">
                                edit
                            </a>
                            <p class="text-zinc-500 ml-40">
                                <%= new Date(post.createdAt).toLocaleDateString("en-US", {
                                    year: "numeric",
                                    month: "long",
                                    day: "2-digit"
                                })%>
                            </p>
                        </div>
                    </div>
                <% })  %>  
                
            </div>
        </div>
        
    </div>
    
</body>
</html>