<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Youtube Backend</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="w-full min-h-screen p-10 bg-zinc-900 text-white" >
        <div class="w-full flex justify-end" >
             <a class="bg-red-600 px-9 py-2 inline-block mb-5 border-none rounded-lg text-sm" href="/logout">Logout</a>
        </div>
        <h3 class="text-3xl mb-5" >Hello , <%= post.createdBy.name %> 👋🏻</h3>
        <h4 class="mb-5" >Edit your post</h4>

        <form action="/edit" method="post">
            <textarea  
                placeholder="What's on your mind..."
                class="w-1/3 p-3 bg-transparent resize-none border-2 border-zinc-700 rounded-lg" 
                name="content" 
                id="" 
        ><%= post.content %></textarea>
            <input class=" px-9 py-2 rounded-lg cursor-pointer block mt-2 bg-blue-500 text-sm   " type="submit" value="Update Post" >
        </form>
    </div>
</body>
</html>